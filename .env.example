# CRAWLTOLL™ — Environment Variables Reference
# Copy to .env and fill in values. Never commit .env to version control.

# ── Payment ─────────────────────────────────────────────────────────────────
# EVM 0x wallet address that receives USDC payments (REQUIRED)
CRAWLTOLL_PAYTO=0xYOUR_WALLET_ADDRESS_HERE

# Price per fetch in USDC (default: 0.005)
CRAWLTOLL_PRICE=0.005

# Network: "base" (mainnet) or "base-sepolia" (testnet)
CRAWLTOLL_NETWORK=base

# ── Server ───────────────────────────────────────────────────────────────────
# Listen port (default: 3000)
PORT=3000

# Directory to serve static files from (default: ./public)
PUBLIC_DIR=./public

# ── Ledger ───────────────────────────────────────────────────────────────────
# Path for the revenue ledger JSONL file
# WARNING: use a persistent volume in production, not /tmp
CRAWLTOLL_LEDGER=/tmp/crawltoll-ledger.jsonl

# ── x402 Facilitator ─────────────────────────────────────────────────────────
# Override x402 facilitator URL (default: https://x402.org/facilitator)
# X402_FACILITATOR_URL=https://x402.org/facilitator

# ── CDP Bazaar Discovery ──────────────────────────────────────────────────────
# Set to "true" to advertise this paywall in the Coinbase CDP Bazaar
X402_BAZAAR_DISCOVERABLE=true

# ── VAPL (Verifiable Agent Provenance Layer) ──────────────────────────────────
# Path to persist the VAPL signing soul (Ed25519 keypair).
# IMPORTANT: Use a persistent volume in production; /tmp is cleared on restart.
# The file contains the private key — set file permissions to 600 after creation.
VAPL_SOUL_FILE=/var/data/vapl_soul_crawltoll.json

# ── Upstream data feed ────────────────────────────────────────────────────────
# SqueezeOS upstream for feed endpoints (default: https://squeezeos-api.onrender.com/api/market/scan)
# SML_UPSTREAM=https://squeezeos-api.onrender.com/api/market/scan

# ── AP2 (Google Agent Payments Protocol) ─────────────────────────────────────
# AP2 mode: "off" | "optional" | "required" (default: optional)
# AP2_MODE=optional

# ── Stats / Admin ─────────────────────────────────────────────────────────────
# Secret token required to access /crawltoll/stats and /crawltoll/visitors
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRAWLTOLL_ADMIN_SECRET=GENERATE_A_STRONG_SECRET_HERE
